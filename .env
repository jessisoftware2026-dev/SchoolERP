# ──────────────────────────────────────────────────────────────
# Jessi ERP — root environment (shared by docker-compose)
# Copy to .env and adjust. Never commit the real .env.
# ──────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=jessi
POSTGRES_PASSWORD=jessi_secret
POSTGRES_DB=jessi_erp
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Core ERP API (NestJS)
API_PORT=4000
DATABASE_URL=postgresql://jessi:jessi_secret@postgres:5432/jessi_erp?schema=public
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=1d
AI_SERVICE_URL=http://ai:8000

# Web app (Next.js)
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://keohwwzakutjxjwlonii.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_05894Jx0b6sEr7UxrPd66g_NdPg4yPc

# AI service (FastAPI)
AI_PORT=8000
# Optional: LLM provider key for the chatbot
OPENAI_API_KEY=
